msgid "H%1$s: All equality restrictions are active (==), H%2$s: At least one equality restriction is violated."
msgstr ""
"H%1$s: Tutte le restrizioni di uguaglianza sono attive (==), H%2$s: Almeno "
"una restrizione di uguaglianza è violata."

msgid "H%1$s: All parameters are restricted to be equal (==), H%2$s: At least one inequality restriction is strictly true (>)."
msgstr ""
"H%1$s: Tutti i parametri sono limitati ad essere uguali (==), H%2$s: Almeno "
"una restrizione di disuguaglianza è strettamente vera (>)."

msgid "H%1$s: All restrictions are equalities (==), H%2$s: At least one inequality restriction is strictly true (>)."
msgstr ""
"H%1$s: Tutte le restrizioni sono uguaglianze (==), H%2$s: Almeno una "
"restrizione di disuguaglianza è strettamente vera (>)."

msgid "H%1$s: All restrictions hold, H%2$s: At least one restriction is violated."
msgstr ""
"H%1$s: Tutte le restrizioni sono valide, H%2$s: Almeno una restrizione è "
"violata."

msgid "H%1$s: At least one restriction is false or active (==), H%2$s: All restrictions are strictly true (>)."
msgstr ""
"H%1$s: Almeno una restrizione è falsa o attiva (==), H%2$s: Tutte le "
"restrizioni sono strettamente vere (>)."

msgid "No marginal means terms specified. Please, select model terms in the 'Restricted Marginal Means' section."
